# Server Configuration
PORT=5000

# MongoDB URI (MongoDB Atlas or Local Instance)
# Replace with your MongoDB Atlas URI string when ready:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/dsa_tracker?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/dsa_tracker

# Nodemailer SMTP Configuration (For daily alerts)
# Set these up if you wish to activate daily email alerts
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-smtp-user-id
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@dsatracker.com
